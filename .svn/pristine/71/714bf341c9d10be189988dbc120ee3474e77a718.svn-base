      <span class="token punctuation" data-v-02330e3a>{</span> key<span class="token operator" data-v-02330e3a>:</span> <span class="token number" data-v-02330e3a>3</span><span class="token punctuation" data-v-02330e3a>,</span> value<span class="token operator" data-v-02330e3a>:</span> <span class="token string" data-v-02330e3a>'名古屋'</span> <span class="token punctuation" data-v-02330e3a>}</span><span class="token punctuation" data-v-02330e3a>,</span>
      <span class="token punctuation" data-v-02330e3a>{</span> key<span class="token operator" data-v-02330e3a>:</span> <span class="token number" data-v-02330e3a>4</span><span class="token punctuation" data-v-02330e3a>,</span> value<span class="token operator" data-v-02330e3a>:</span> <span class="token string" data-v-02330e3a>'沖縄'</span> <span class="token punctuation" data-v-02330e3a>}</span><span class="token punctuation" data-v-02330e3a>,</span>
