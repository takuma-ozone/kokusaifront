<template>
  <div :class="['ra-panel', panelClass ? panelClass : '']">
    <div class="ra-panel-header">
      <span class="ra-panel-title" v-if="!titleRight">{{ title }}</span>
      <span class="ra-panel-title-right" v-if="titleRight">{{ title }}</span>
      <ra-button
        id="openButton"
        v-if="openable"
        @click="toggleOpen"
        :icon="openIcon"
        circle
      ></ra-button>
    </div>
    <div :class="isOpenComputed ? 'ra-panel-content' : ''">
      <!-- バリデーションを実施する場合は<form>タグで囲う -->
      <template v-if="hasValidation">
        <form :data-vv-scope="scope">
          <slot v-if="isOpenComputed"></slot>
        </form>
      </template>
      <template v-else>
        <slot v-if="isOpenComputed"></slot>
      </template>
    </div>
  </div>
</template>

<script>
export default {
  name: 'RaPanel',
  componentName: 'RaPanel',

  inject: ['$validator'],

  props: {
    title: String,
    titleRight: {
      type: Boolean,
      default: false,
    },
    panelClass: String,

    isOpen: {
      type: Boolean,
      default: true,
    },

    openable: {
      type: Boolean,
      default: false,
    },

    // veeValidate対応
    hasValidation: {
      type: Boolean,
      default: false,
    },

    scope: {
      type: String,
      default: 'defaultScope',
    },
  },

  data() {
    return {};
  },

  methods: {
    toggleOpen() {
      this.isOpenComputed = !this.isOpenComputed;
    },
  },

  computed: {
    isOpenComputed: {
      get() {
        return this.isOpen;
      },
      set(value) {
        this.$emit('update:isOpen', value);
      },
    },
    openIcon() {
      return this.isOpenComputed ? 'el-icon-arrow-down' : 'el-icon-arrow-up';
    },
  },
};
</script>

<style lang="scss" scoped>
$--content-theme-color: #5866c2;

.ra-panel {
  width: 100%;
  border: solid 1px lightgray;

  .ra-panel-header {
    width: 100%;
    height: 25px;
    color: white;
    background-color: $--content-theme-color;

    .ra-panel-title {
      // titleをpanel-headerの上下中央に配置
      position: relative;
      top: 15%;
      transform: translateY(-50%);
      width: 90%;
      left: 10px;
    }

    .ra-panel-title-right {
      // titleをpanel-headerの上下中央に配置
      position: relative;
      top: 15%;
      transform: translateY(-50%);
      // titleを右端に配置
      text-align: right;
      width: 90%;
      right: 10px;
    }
  }

  .ra-panel-content {
    background-color: rgb(245, 250, 255);
    padding: 8px 10px;
  }

  #openButton {
    left: 20px;
    top: 10%;
  }
}
</style>
