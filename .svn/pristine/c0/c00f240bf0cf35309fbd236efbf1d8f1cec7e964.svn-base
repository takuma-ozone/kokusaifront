// TODO: 開発ガイドを見て変更してください
.Sample {
  display: grid;
	grid-template:
		"left1 right1" 22px
		"left2 right2" 22px
		"left3 right3-5" 22px
		"left4 right3-5" 22px
		"left5 right3-5" 22px
		"empty empty" 26px /
		1fr 1fr;
}

// TODO: 開発ガイドを見て変更してください
$areas: left1, left2, left3, left4, left5, right1, right2, right3-5, empty;

@each $area in $areas {
  .#{$area} {
    grid-area: #{$area};
  }
}


@charset "utf-8";
