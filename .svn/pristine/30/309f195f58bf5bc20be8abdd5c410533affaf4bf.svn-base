  <span class="token attr-name" data-v-02330e3a>data-vv-as</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>携帯電話<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
