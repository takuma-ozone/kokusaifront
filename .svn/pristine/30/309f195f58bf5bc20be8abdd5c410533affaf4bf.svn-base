  <span class="token attr-name" data-v-02330e3a>com-id</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>after_str<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
  <span class="token attr-name" data-v-02330e3a>v-model</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>value<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
  <span class="token attr-name" data-v-02330e3a>input-width</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>3<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
  <span class="token attr-name" data-v-02330e3a>caption</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>AFTER<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
  <span class="token attr-name" data-v-02330e3a>:validate</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>{ after: beforeDay, date_format: 'yyyy/MM/dd' }<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
<span class="token punctuation" data-v-02330e3a>&gt;</span></span>
<span class="token tag" data-v-02330e3a><span class="token tag" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>&lt;/</span>rm-date-picker</span><span class="token punctuation" data-v-02330e3a>&gt;</span></span>
