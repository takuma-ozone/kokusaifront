s="sidebar-link">✔️ zipcode</a></li><li class="sidebar-sub-header"><a href="/frontend/validations/availableRules.html#regex" class="sidebar-link">✔️ regex</a></li></ul></li><li><a href="/frontend/validations/availableRules.html#number-validation-rules" class="sidebar-link">🔷 Number Validation Rules</a><ul class="sidebar-sub-headers"><li class="sidebar-sub-header"><a href="/frontend/validations/availableRules.html#max-value" class="sidebar-link">✔️ max_value</a></li><li class="sidebar-sub-header"><a href="/frontend/validations/availableRules.html#min-value" class="sidebar-link">✔️ min_value</a></li><li class="sidebar-sub-header"><a href="/frontend/validations/availableRules.html#between" class="sidebar-link">✔️ between</a></li></ul></li><li><a href="/frontend/validations/availableRules.html#date-validation-rules" class="sidebar-link">🔷 Date Validation Rules</a><ul class="sidebar-sub-headers"><li class="sidebar-sub-header"><a href="/frontend/validations/availableRules.html#date-format" class="sidebar-link">✔️ date_format</a></li><li class="sidebar-sub-header"><a href="/frontend/validations/availableRules.html#after" class="sidebar-link">✔️ after</a></li><li class="sidebar-sub-header"><a href="/frontend/validations/availableRules.html#before" class="sidebar-link">✔️ before</a></li><li class="sidebar-sub-header"><a href="/frontend/validations/availableRules.html#date-between" class="sidebar-link">✔️ date_between</a></li></ul></li><li><a href="/frontend/validations/availableRules.html#correlation-rules" class="sidebar-link">🔷 Correlation Rules</a><ul class="sidebar-sub-headers"><li class="sidebar-sub-header"><a href="/frontend/validations/availableRules.html#required-any" class="sidebar-link">✔️ required_any</a></li><li class="sidebar-sub-header"><a href="/frontend/validations/availableRules.html#required-all" class="sidebar-link">✔️ required_all</a></li></ul></li></ul></section></li></ul> </aside> <main class="page"> <div class="theme-default-content content__default"><h1 id="validation-rules"><a href="#validation-rules" class="header-anchor">#</a> 📗 Validation Rules</h1> <p><a href="https://baianat.github.io/vee-validate/guide/rules.html#validation-rules" target="_blank" rel="noopener noreferrer">VeeValidate 標準ルール<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" x="0px" y="0px" viewBox="0 0 100 100" width="15" height="15" class="icon outbound"><path fill="currentColor" d="M18.8,85.1h56l0,0c2.2,0,4-1.8,4-4v-32h-8v28h-48v-48h28v-8h-32l0,0c-2.2,0-4,1.8-4,4v56C14.8,83.3,16.6,85.1,18.8,85.1z"></path> <polygon fill="currentColor" points="45.7,48.7 51.3,54.3 77.2,28.5 77.2,37.2 85.2,37.2 85.2,14.9 62.8,14.9 62.8,22.9 71.5,22.9"></polygon></svg></a>と高速開発 FW 独自拡張ルールが利用できます。</p> <div class="custom-block warning"><p class="custom-block-title">WARNING</p> <p>本ガイドでは<code>VeeValidate</code>標準ルールのうち、利用が予想されるものだけを記載しています。<br>
その他のルールは、<a href="https://baianat.github.io/vee-validate/guide/rules.html#validation-rules" target="_blank" rel="noopener noreferrer">VeeValidate 標準ルール<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" x="0px" y="0px" viewBox="0 0 100 100" width="15" height="15" class="icon outbound"><path fill="currentColor" d="M18.8,85.1h56l0,0c2.2,0,4-1.8,4-4v-32h-8v28h-48v-48h28v-8h-32l0,0c-2.2,0-4,1.8-4,4v56C14.8,83.3,16.6,85.1,18.8,85.1z"></path> <polygon fill="currentColor" points="45.7,48.7 51.3,54.3 77.2,28.5 77.2,37.2 85.2,37.2 85.2,14.9 62.8,14.9 62.8,22.9 71.5,22.9"></polygon></svg></a>をご参照ください。</p></div> <h2 id="basic-rules"><a href="#basic-rules" class="header-anchor">#</a> 🔷 Basic Rules</h2> <h3 id="required"><a href="#required" class="header-anchor">#</a> ✔️ <code>required</code></h3> <p>要素が null でも空でもないかを検証します。</p> <ul><li><a href="https://baianat.github.io/vee-validate/guide/rules.html#required" target="_blank" rel="noopener noreferrer">required<svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" x="0px" y="0px" viewBox="0 0 100 100" width="15" height="15" class="icon outbound"><path fill="currentColor" d="M18.8,85.1h56l0,0c2.2,0,4-1.8,4-4v-32h-8v28h-48v-48h28v-8h-32l0,0c-2.2,0-4,1.8-4,4v56C14.8,83.3,16.6,85.1,18.8,85.1z"></path> <polygon fill="currentColor" points="45.7,48.7 51.3,54.3 77.2,28.5 77.2,37.2 85.2,37.2 85.2,14.9 62.8,14.9 62.8,22.9 71.5,22.9"></polygon></svg></a></li></ul> <div class="code-preview" data-v-02330e3a><div class="code" data-v-02330e3a><div class="language-vue line-numbers-mode" data-v-02330e3a><pre class="language-vue" data-v-02330e3a><code data-v-02330e3a><span class="token tag" data-v-02330e3a><span class="token tag" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>&lt;</span>ro-message-guide</span><span class="token punctuation" data-v-02330e3a>&gt;</span></span><span class="token tag" data-v-02330e3a><span class="token tag" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>&lt;/</span>ro-message-guide</span><span class="token punctuation" data-v-02330e3a>&gt;</span></span>

<span class="token tag" data-v-02330e3a><span class="token tag" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>&lt;</span>rm-input</span>
  <span class="token attr-name" data-v-02330e3a>com-id</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>required_str<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
  <span class="token attr-name" data-v-02330e3a>v-model</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>value<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
  <span class="token attr-name" data-v-02330e3a>input-width</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>3<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
  <span class="token attr-name" data-v-02330e3a>caption</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>REQUIRED<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
