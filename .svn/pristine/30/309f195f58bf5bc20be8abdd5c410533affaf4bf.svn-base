    <span class="token keyword">return</span> <span class="token punctuation">{</span> beforeDay<span class="token operator">:</span> <span class="token string">'2019/09/10'</span> <span class="token punctuation">}</span><span class="token punctuation">;</span>
  <span class="token punctuation">}</span><span class="token punctuation">,</span>
