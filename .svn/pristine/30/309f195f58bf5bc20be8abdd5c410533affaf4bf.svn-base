  <span class="token attr-name" data-v-02330e3a>caption</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>DATE_FORMAT<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
  <span class="token attr-name" data-v-02330e3a>validate</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span>date_format:yyyy/MM/dd<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
