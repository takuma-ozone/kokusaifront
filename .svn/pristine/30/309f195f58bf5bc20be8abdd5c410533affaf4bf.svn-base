  <span class="token attr-name" data-v-02330e3a>v-validate</span><span class="token attr-value" data-v-02330e3a><span class="token punctuation" data-v-02330e3a>=</span><span class="token punctuation" data-v-02330e3a>&quot;</span><span class="token punctuation" data-v-02330e3a>'</span>required_any:kotei'<span class="token punctuation" data-v-02330e3a>&quot;</span></span>
